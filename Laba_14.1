import random

list = [[random.randint(0,100)
         for i in range(5)] for j in range(5)]

print(list)
max_znach = 0
position = 0

for i, item in enumerate(list):
    for j, value in enumerate(item):
        if value > list[max_znach][position]:
            max_znach, position = i, j

print(f"список с максимальным элементов: {list[max_znach][position]}")
print(f"маскимальное значение в списке: {max_znach}")
print(f"позиция в строке: {position}")
