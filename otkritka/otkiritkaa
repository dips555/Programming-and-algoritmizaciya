FLOVER_COLOR_2 = ("pink")
FLOVER_COLOR_3 = ("yellow")
FLOVER_COLOR_4 = ("orange")



# =====================================================
# ОБЛАКО
# =====================================================


t.color(COLOR_CLOUD)
coords = [
    (100, 280, 40),
    (70, 290, 30),
    (130, 290, 30),
    (50, 270, 25),
    (150, 270, 25),
    (100, 260, 35)
]

for x, y, z in coords:
    t.penup()
    t.goto(x, y -z)
    t.pendown()
    t.begin_fill()
    t.circle(z)
    t.end_fill()

t.color(COLOR_CLOUD)
coords = [
    (-150, 280, 40),
    (-105, 290, 30),
    (-195, 290, 30),
    (-100, 270, 25),
    (-200, 270, 25),
    (-150, 260, 35)
]

