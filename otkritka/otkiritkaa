#трава
t.color(COLOR_GRASS)
for i in range(COUNT_GRASS):
    t.penup()
    t.goto(-300 + i * 25, -300)
    t.pendown()
    d = 1 if i % 2 == 0 else -1
    t.setheading(75 + (i % 5) * 10)
    t.width(3 - (i % 2))
    n = 70 + (i % 30)
    for j in range(int(n / 10)):
        t.forward(GRASS_LEN)
        t.left(5 * d)
    t.width(1)

t.color(COLOR_GRASS)
for i in range(COUNT_GRASS):
    t.penup()
