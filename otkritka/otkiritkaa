import turtle

t = turtle.Turtle()
t.speed(0)
t.hideturtle()
screen = turtle.Screen()
screen.bgcolor("lightblue")
screen.setup(width=800, height=700)

#  КОНСТАНТЫ

#  ОБЛАКА
COLOR_CLOUD = "white"

#  СОЛНЦЕ
SUN_COLOR = "orange"
CIRCLE_COLOR = "yellow"
COUNT_LUCH = (16)
LEN_LUCH = (90)
RADIUS_SUN = (50)
SHIRINA = (6)


#  НАДПИСЬ
COLOR_WRITE_1 = ("deeppink")
COLOR_WRITE_2 = ("green")
COLOR_WRITE_3 = ("pink")
TEXT_1 = ("C 24 Апреля?")
TEXT_2 = ("Родные!")
